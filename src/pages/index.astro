<!-- Resume Section -->
<section id="resume" class="my-12 px-6 bg-gray-100 py-12 rounded-xl">
  <h2 class="text-3xl font-bold mb-6 text-center">Resume & Personal Projects 🐢</h2>

  <div class="max-w-3xl mx-auto">
    <h3 class="text-xl font-semibold mb-2">About Me</h3>
    <p class="mb-4">Cloud & Homelab enthusiast, building automated and observable infrastructures. Passionate about IoT, robotics, and smart home integration.</p>

    <h3 class="text-xl font-semibold mb-2">Skills</h3>
    <ul class="list-disc list-inside mb-4">
      <li>Docker, Prometheus, Grafana, Uptime Kuma, Tailscale</li>
      <li>Home Assistant, ESPHome, Raspberry Pi, IoT Automation</li>
      <li>Pi-hole, CrowdSec, Watchtower, Linux Server Administration</li>
      <li>Python, Bash scripting, Cloud experimentation (GCP/Ubuntu LTS)</li>
    </ul>

    <h3 class="text-xl font-semibold mb-2">Interactive ML Resume Assistant</h3>
    <p class="mb-2">Test out skill suggestions based on your experience:</p>
    <textarea id="experienceInput" class="w-full p-2 border rounded mb-2" rows="3" placeholder="Paste your experience here..."></textarea>
    <button id="suggestSkills" class="bg-blue-500 text-white px-4 py-2 rounded mb-4 hover:bg-blue-600">Suggest Skills</button>
    <div id="suggestedSkills" class="text-gray-700 font-medium"></div>

    <script type="module">
      const button = document.getElementById('suggestSkills');
      const input = document.getElementById('experienceInput');
      const output = document.getElementById('suggestedSkills');

      button.addEventListener('click', () => {
        const text = input.value.toLowerCase();
        const skills = [];
        if(text.includes('docker')) skills.push('Docker');
        if(text.includes('prometheus')) skills.push('Prometheus');
        if(text.includes('grafana')) skills.push('Grafana');
        if(text.includes('home assistant')) skills.push('Home Assistant');
        if(text.includes('python')) skills.push('Python');
        if(text.includes('gcp')) skills.push('GCP');
        output.textContent = skills.length ? 'Suggested Skills: ' + skills.join(', ') : 'No skills detected';
      });
    </script>
  </div>
</section>
